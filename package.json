{
  "name": "test-data-factory",
  "version": "1.0.0",
  "description": "Type-safe test data factory library for TypeScript — build complex, realistic test data with minimal boilerplate",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --check \"**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "author": "Quvantic <info@quvantic.com> (https://quvantic.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mustafaautomation/test-data-factory.git"
  },
  "homepage": "https://github.com/mustafaautomation/test-data-factory#readme",
  "bugs": {
    "url": "https://github.com/mustafaautomation/test-data-factory/issues"
  },
  "dependencies": {
    "@faker-js/faker": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.8.3",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": ["dist"]
}
